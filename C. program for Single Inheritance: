class A
{
    void sqr(int a)
    {
        System.out.println(a * a);
    }
}

class B extends A
{
    void cube(int b)
    {
        System.out.println(b * b * b);
    }
}

class Pract5
{
    public static void main(String args[])
    {
        B s = new B();
        s.sqr(5);
        s.cube(5);
    }
}
