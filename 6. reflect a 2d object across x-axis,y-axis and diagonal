import matplotlib.pyplot as plt

object_points = [(2,3), (4,5), (6,3)]
x, y = zip(*object_points)

x_xaxis = x
y_xaxis = tuple([-yi for yi in y])

x_yaxis = tuple([-xi for xi in x])
y_yaxis = y

x_diag = y
y_diag = x

plt.figure()

plt.plot(x + (x[0],), y + (y[0],), marker='o', label='Original')

plt.plot(x_xaxis + (x_xaxis[0],), y_xaxis + (y_xaxis[0],),
         marker='o', label='X-axis Reflection')

plt.plot(x_yaxis + (x_yaxis[0],), y_yaxis + (y_yaxis[0],),
         marker='o', label='Y-axis Reflection')

plt.plot(x_diag + (x_diag[0],), y_diag + (y_diag[0],),
         marker='o', label='Diagonal Reflection (y=x)')

plt.axhline(0)
plt.axvline(0)

plt.xlabel('X-axis')
plt.ylabel('Y-axis')
plt.legend()
plt.grid(True)
plt.title('2D Object Reflection')

plt.show()
