import matplotlib.pyplot as plt

r = 8
x = 0
y = r
p = 1 - r

X = []
Y = []

while x <= y:
    X += [x, -x, x, -x, y, -y, y, -y]
    Y += [y, y, -y, -y, x, x, -x, -x]

    x += 1

    if p < 0:
        p = p + 2*x + 1
    else:
        y -= 1
        p = p + 2*x - 2*y + 1

plt.scatter(X, Y)
plt.gca().set_aspect('equal')
plt.title("Midpoint Circle Algorithm (r=8)")
plt.show()
