import matplotlib.pyplot as plt

x = [1, 4, 2, 1]
y = [1, 1, 4, 1]

face = "front"   # change to "back" to test

plt.figure()

if face == "front":
    plt.plot(x, y, marker='o')
    plt.fill(x, y, alpha=0.6)
    plt.title("Front Face (Drawn)")
else:
    plt.title("Back Face (Removed)")

plt.xlabel("X-axis")
plt.ylabel("Y-axis")
plt.grid(True)

plt.show()
