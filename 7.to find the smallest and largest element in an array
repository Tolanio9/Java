class Pract9 {
    public static void main(String[] args) {
        int num[] = {13, 22, 27, 4, 14};

        int l = num[0];
        int s = num[0];

        for (int i = 1; i < num.length; i++) {
            if (num[i] > l) {
                l = num[i];
            } else if (num[i] < s) {
                s = num[i];
            }
        }

        System.out.println("Largest Number: " + l);
        System.out.println("Smallest Number: " + s);
    }
}
